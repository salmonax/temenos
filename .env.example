# Anthropic API key — required for the Planner and stance LLM calls
ANTHROPIC_API_KEY=

# Primary LLM for planning and stance execution
ANTHROPIC_MODEL=claude-opus-4-6

# Optional: cheaper model for inner calls (summarization, classification)
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001

# Active instance — which subdirectory under src/instances/ to load
TEMENOS_INSTANCE=poseida-vault

# Logging
LOG_LEVEL=info
